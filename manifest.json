{
  "manifest_version": 3,
  "name": "Microslop Extension",
  "version": "1.0",
  "description": "Changes every occurrence of 'microsoft' to 'microslop' on all websites.",
  "content_scripts": [
    {
      "matches": ["<all_urls>"],
      "js": ["content.js"],
      "run_at": "document_end"
    }
  ],
  "browser_specific_settings": {
    "gecko": {
      "id": "microslop@example.com"
    }
  }
}
